# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=hob_hud

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_LOCAL_PATH=C:/c/data/qdrant   # Alternative: local file mode (no server needed)
QDRANT_API_KEY=                         # Leave blank for local instance
QDRANT_DEFAULT_COLLECTION=hob_hud

# Embedding model (fastembed — runs locally, no API cost)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2