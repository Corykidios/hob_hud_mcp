NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=your_nim_key_here
OPENAI_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
OPENAI_VECTOR_DIMENSION=1024
OPENAI_INFERENCE_MODEL=meta/llama-3.3-70b-instruct

DEFAULT_MODEL_PROVIDER=openai
USE_SPACY_EXTRACTOR=false

HOB_HUD_GRAPH_RAG_DIR=C:\c\apps\Qdrant-Neo4j-Ollama-Graph-Rag
HOB_HUD_ENV=C:\c\apps\Qdrant-Neo4j-Ollama-Graph-Rag\.env

PARALLEL_PROCESSING=true
MAX_WORKERS=4
BATCH_SIZE=100
CHUNK_SIZE=5000
USE_STREAMING=false
COLLECTION_NAME=graphRAGstoreds
